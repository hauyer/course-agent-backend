# 复制为 .env 后再填写。不要提交真实 .env、密码、Token 或 API Key。

# MySQL 8（建议使用独立、最小权限账号，不要在应用中使用 root）
DATABASE_URL=mysql+pymysql://course_agent:CHANGE_ME@127.0.0.1:3306/course_agent?charset=utf8mb4

# 使用至少 48 字节随机值，例如：python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 本地向量检索
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=course_material_chunks
RAG_TOP_K=5

# 默认模型。也可以登录后在“设置 → 外部大模型”中按用户配置。
# LangChain 通用格式示例：deepseek:deepseek-chat
LLM_MODEL=deepseek:deepseek-chat
DEEPSEEK_API_KEY=REPLACE_WITH_YOUR_API_KEY
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=60
MAX_TOKENS=20000

# 可选：开发环境的全局回退配置。桌面端建议在应用内按用户配置。
OBSIDIAN_VAULT_PATH=
OBSIDIAN_BASE_FOLDER=课程学习助手
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_API_VERSION=2022-06-28
NOTION_TIMEOUT_SECONDS=30
