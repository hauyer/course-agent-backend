# 复制为 .env 后填写。不要提交真实 .env、密码、Token 或 API Key。

# MySQL 8：建议使用独立、最小权限账号，不要使用 root。
DATABASE_URL=mysql+pymysql://course_agent:CHANGE_ME@127.0.0.1:3306/course_agent?charset=utf8mb4

# 至少使用 48 字节随机值：python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 1.1 本地余弦向量检索。
# CHROMA_COLLECTION_NAME 是新变量；仍兼容旧变量 CHROMA_COLLECTION。
# 不要把旧 course_material_chunks 改名或删除。
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION_NAME=course_material_chunks_v1_1_cosine
SEMANTIC_SEARCH_TOP_K=5
SEMANTIC_SEARCH_MAX_TOP_K=20
SEMANTIC_SEARCH_MIN_SIMILARITY=0.35
SEMANTIC_SEARCH_MAX_QUERY_LENGTH=2000
SEMANTIC_SEARCH_MAX_CANDIDATES=50
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_NORMALIZE=true
EMBEDDING_BATCH_SIZE=16
# 仅测试/诊断时开启；生产请求默认不逐条计算模长。
EMBEDDING_VALIDATE_NORMS=false

# 默认模型。也可登录后在“设置 → 外部大模型”中按用户配置。
LLM_MODEL=deepseek:deepseek-chat
DEEPSEEK_API_KEY=REPLACE_WITH_YOUR_API_KEY
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=60
MAX_TOKENS=20000

# 可选的开发环境集成。桌面端建议在应用中按用户配置。
OBSIDIAN_VAULT_PATH=
OBSIDIAN_BASE_FOLDER=课程学习助手
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_API_VERSION=2022-06-28
NOTION_TIMEOUT_SECONDS=30
